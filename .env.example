# ═══════════════════════════════════════════
# Cashback Stack — Environment Variables
# Скопируйте в .env и заполните, либо запустите install.sh.
#
# Пароли (MariaDB / SMTP / Grafana admin) НЕ в этом файле — они хранятся
# в secrets/*.txt и подхватываются как Docker secrets, чтобы не светиться
# через `docker inspect` контейнера.
# ═══════════════════════════════════════════

DOMAIN=cashback.example.com
ACME_EMAIL=admin@example.com

# MariaDB (только имена; пароли — в secrets/db_*_password.txt)
MYSQL_DATABASE=cashback_db
MYSQL_USER=cashback_user

# SMTP (логин и сервер; пароль — в secrets/smtp_password.txt)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_SECURE=tls
SMTP_FROM=noreply@example.com

# Куда слать алерты Grafana (можно несколько через запятую)
ALERT_EMAIL=ops@example.com

# Пароль read-only пользователя exporter в MariaDB.
# Используется только в setup-mariadb-users.sh; ALTER USER идемпотентен.
MYSQL_EXPORTER_PASSWORD=CHANGE_ME
