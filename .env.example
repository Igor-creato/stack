# ═══════════════════════════════════════════
# Cashback Stack — Environment Variables
# Скопируйте в .env и заполните, либо запустите install.sh
# ═══════════════════════════════════════════

DOMAIN=cashback.example.com
ACME_EMAIL=admin@example.com

# MariaDB
MYSQL_ROOT_PASSWORD=CHANGE_ME
MYSQL_DATABASE=cashback_db
MYSQL_USER=cashback_user
MYSQL_PASSWORD=CHANGE_ME

# WordPress Salts (сгенерировать: openssl rand -base64 64)
WP_AUTH_KEY=CHANGE_ME
WP_SECURE_AUTH_KEY=CHANGE_ME
WP_LOGGED_IN_KEY=CHANGE_ME
WP_NONCE_KEY=CHANGE_ME
WP_AUTH_SALT=CHANGE_ME
WP_SECURE_AUTH_SALT=CHANGE_ME
WP_LOGGED_IN_SALT=CHANGE_ME
WP_NONCE_SALT=CHANGE_ME
